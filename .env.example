# Firebase Configuration
# The app will automatically load from: lagos-rhythm-virtual-tour-firebase-adminsdk-fbsvc-6c40080af4.json
# (This file is gitignored for security. Provide your own service account key.)
#
# Alternative: Provide credentials via environment variable (base64-encoded or raw JSON):
# FIREBASE_SERVICE_ACCOUNT_KEY="your-base64-encoded-json-or-raw-json"
#
# Priority:
# 1. Local file (if exists)
# 2. FIREBASE_SERVICE_ACCOUNT_KEY env var
# 3. If neither exists, Firebase will fail (expected for CI/CD without credentials)

# Optional: Uncomment to override with env var if needed
# FIREBASE_SERVICE_ACCOUNT_KEY=

# Firebase Authentication
# For admin login, you'll need to:
# 1. Enable Email/Password authentication in Firebase Console
# 2. Create admin users in Firebase Authentication
# 3. The admin login UI uses the Firebase identitytoolkit REST API directly
# 4. VITE_FIREBASE_API_KEY is your Firebase project's Web API Key
#    Find it in: Firebase Console → Project Settings → General → Web API Key
VITE_FIREBASE_API_KEY=your-firebase-web-api-key

# Server Configuration
PORT=3000
NODE_ENV=development

# Live Tour Configuration (fallback if Firestore is unavailable)
LIVE_TOUR_ACTIVE=false
LIVE_TOUR_TITLE=
LIVE_TOUR_DESCRIPTION=
LIVE_TOUR_HOST=
LIVE_TOUR_LOCATION=
LIVE_TOUR_VIEWERS=
LIVE_TOUR_STARTED_LABEL=
LIVE_TOUR_STREAM_IMAGE=
LIVE_TOUR_HOST_IMAGE=

# WebSocket
VITE_TOUR_STATUS_WS_URL=ws://localhost:3000/api/live
