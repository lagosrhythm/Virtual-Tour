{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["src/**"]
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!assets|favicon.ico|api|admin).*)",
      "destination": "/index.html"
    }
  ]
}
