{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!assets|favicon.ico|api|admin).*)",
      "destination": "/index.html"
    }
  ]
}
